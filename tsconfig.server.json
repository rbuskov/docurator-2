{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "noEmit": false,
    "outDir": "dist/server",
    "rootDir": "src/server",
    "declaration": false,
    "sourceMap": true
  },
  "include": ["src/server/**/*"],
  "exclude": ["src/server/**/*.test.ts"]
}
