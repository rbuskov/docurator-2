{
  "name": "docurator",
  "version": "0.0.0",
  "private": true,
  "description": "Self-hosted Gmail receipt curator (see docs/vision.md).",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n server,client -c blue,magenta \"NODE_ENV=development tsx watch --env-file=.env src/server/index.ts\" \"vite\"",
    "check:gmail-readonly": "tsx scripts/check-gmail-readonly.ts",
    "build": "npm run check:gmail-readonly && vite build && tsc -p tsconfig.server.json && node -e \"require('node:fs').cpSync('src/server/db/migrations','dist/server/db/migrations',{recursive:true})\"",
    "start": "NODE_ENV=production node --env-file=.env dist/server/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "better-sqlite3": "^12.9.0",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "hono": "^4.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
