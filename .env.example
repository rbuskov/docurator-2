# Docurator environment variables.
# Copy this file to `.env` and fill in your own values; `.env` is gitignored.
# See README setup walkthrough for the Google Cloud OAuth client steps.

# Server port (mapped to the host via docker-compose.yml).
APP_PORT=3737

# Google OAuth credentials — Desktop-app client type, per architecture.md
# § "Open source considerations". Each user supplies their own.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Port appearing in the OAuth redirect URI. Defaults to APP_PORT, which is
# almost always what you want. Set this only if the container's external port
# differs from APP_PORT (e.g. you're running behind a reverse proxy).
# OAUTH_REDIRECT_PORT=

# NODE_ENV gates dev-only endpoints (POST /api/dev/processed-messages/seed,
# GET /api/dev/enabled). Set to "production" to disable; defaults to
# "development". Production builds set this automatically.
# NODE_ENV=production

# Ollama base URL. Default points at the host's Ollama via Docker's
# host-gateway alias; override on Linux when host.docker.internal does not
# resolve (try http://172.17.0.1:11434 — the default Docker bridge gateway).
# OLLAMA_URL=http://host.docker.internal:11434

# Ollama model name. Must be installed on the host (`ollama pull qwen2.5vl:7b`).
# Vision-capable models are required for attachment-bearing receipts.
# OLLAMA_MODEL=qwen2.5vl:7b

# Per-classify-request timeout in milliseconds. Defaults to 120s — vision
# inference on a CPU-bound host can take tens of seconds. Non-numeric or
# non-positive values fall back to the default.
# OLLAMA_TIMEOUT_MS=120000

# Default sync window in days. Used when POST /api/sync omits `since`. The
# request body's `since` field overrides this per call.
# SYNC_DEFAULT_WINDOW_DAYS=30

# How many classify calls run in parallel against Ollama. Default 1 because
# Ollama is the bottleneck and overlapping inference doesn't help. Bumping
# only makes sense if you have a much larger GPU and a non-trivial backlog.
# MAX_CONCURRENT_CLASSIFY=1
